# ── Dependencies ───────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ───────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.vite/
*.tsbuildinfo

# ── Environment files (never commit secrets) ───────────────────────────
.env
.env.*
!.env.example
*.local

# ── Logs ───────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / IDE ───────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Claude Code per-user settings ──────────────────────────────────────
# Project-level settings.json is committed; per-user overrides are not.
# `**/` prefix matches at any depth (top-level .claude/ and brewlab/.claude/).
**/.claude/settings.local.json

# ── OS junk ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Test / coverage ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ───────────────────────────────────────────────────────────────
*.bak
*.orig
*.tmp

# ── Local fixtures / test backups (do not commit) ──────────────────────
fake-*.json
brewlab-backup-*.json
